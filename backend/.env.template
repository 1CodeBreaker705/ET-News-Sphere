# Backend Environment Variables Template
# Copy this file to .env and fill in your values

SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_service_role_key

# Qdrant Cloud (Leave empty for local persistent storage)
QDRANT_URL=your_qdrant_cloud_url
QDRANT_API_KEY=your_qdrant_cloud_api_key

# Google Gemini API (Required for embeddings and LLM)
GOOGLE_API_KEY=your_google_ai_studio_api_key

# CORS Settings (Comma-separated list of allowed frontend URLs)
CORS_ORIGINS=http://localhost:5173,https://your-deployed-frontend.vercel.app
